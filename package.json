{
  "name": "uptime-flare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18.0",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "vite dev",
    "d1:init": "wrangler d1 execute uptime_flare --local --file init.sql --persist-to .wrangler-local/state",
    "d1:list": "wrangler d1 execute uptime_flare --local --command \"SELECT key FROM monitor_state\" --persist-to .wrangler-local/state",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "build": "vite build && rm -f dist/server/.dev.vars",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "dayjs": "^1.11.21",
    "p-limit": "^7.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uplot": "^1.6.32",
    "uplot-react": "^1.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@cloudflare/vite-plugin": "^1.42.4",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.2",
    "wrangler": "^4.106.0"
  }
}
